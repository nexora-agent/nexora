{
  "name": "nexora",
  "private": true,
  "version": "0.1.0",
  "description": "Verifiable Safety Layer for On-Chain AI Agents.",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --parallel dev",
    "dev:web": "pnpm --filter @nexora/web dev",
    "dev:api": "pnpm --filter @nexora/api dev",
    "dev:local-harness": "node tools/local-harness-example.mjs",
    "mcp:example": "node tools/mcp-client-example.mjs",
    "mcp:basic": "node tools/basic-mcp-example.mjs",
    "mcp:byreal-example": "node tools/byreal-mcp-example.mjs",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "contracts:build": "forge build --root contracts",
    "contracts:test": "forge test --root contracts",
    "contracts:deploy:mantle": "bash contracts/script/deploy-mantle.sh",
    "contracts:deploy:preflight": "bash contracts/script/deploy-preflight-registry.sh",
    "contracts:deploy:agent-wallets": "bash contracts/script/deploy-agent-wallets.sh",
    "contracts:deploy:benchmark-registry": "bash contracts/script/deploy-benchmark-registry.sh",
    "contracts:deploy:benchmark-dex": "bash contracts/script/deploy-benchmark-dex.sh",
    "contracts:deploy:agent-wallets:windows": "powershell -ExecutionPolicy Bypass -File contracts\\script\\deploy-agent-wallets.ps1",
    "contracts:deploy:vaults": "bash contracts/script/deploy-benchmark-vaults.sh",
    "agent:runner": "pnpm --filter @nexora/api agent:runner",
    "nexora:dev": "bash tools/nexora-manual-test.sh dev",
    "nexora:api": "bash tools/nexora-manual-test.sh api",
    "nexora:web": "bash tools/nexora-manual-test.sh web",
    "nexora:harness": "bash tools/nexora-manual-test.sh harness",
    "nexora:mcp": "bash tools/nexora-manual-test.sh mcp",
    "nexora:mcp-basic": "pnpm mcp:basic",
    "nexora:byreal-mcp": "bash tools/nexora-manual-test.sh byreal-mcp",
    "nexora:ollama": "bash tools/nexora-manual-test.sh ollama",
    "nexora:status": "bash tools/nexora-manual-test.sh status",
    "nexora:runner": "bash tools/nexora-manual-test.sh runner"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
