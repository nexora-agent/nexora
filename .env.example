# ---------------------------------------------------------------------------
# Local API network/security
# ---------------------------------------------------------------------------
HOST=127.0.0.1
PORT=4000
NEXORA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional local runner API key.
# If set, every /runner/* request must include this value in x-nexora-runner-key.
NEXORA_RUNNER_API_KEY=

# ---------------------------------------------------------------------------
# Demo mode (frontend)
# Local live mode (default): demo mode "local", hosted preview off.
# Hosted preview mode (Vercel): demo mode "hosted", hosted preview on,
# empty API base URL, no private keys.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_NEXORA_DEMO_MODE=local
NEXT_PUBLIC_NEXORA_HOSTED_PREVIEW=false
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4000
NEXT_PUBLIC_MANTLE_EXPLORER_URL=https://explorer.sepolia.mantle.xyz

# Optional recorded Mantle proof links shown in hosted preview mode.
NEXT_PUBLIC_DEMO_AGENT_ID=
NEXT_PUBLIC_DEMO_SMART_WALLET=
NEXT_PUBLIC_DEMO_BENCHMARK_REGISTRY=
NEXT_PUBLIC_DEMO_VALIDATION_TX=
NEXT_PUBLIC_DEMO_EXECUTION_TX=
NEXT_PUBLIC_DEMO_REPUTATION_TX=
NEXT_PUBLIC_DEMO_REPORT_HASH=

# ---------------------------------------------------------------------------
# Mantle RPC / executor config
# ---------------------------------------------------------------------------
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
NEXT_PUBLIC_NEXORA_START_BLOCK=39141900
NEXT_PUBLIC_NEXORA_ACTIVITY_LOG_WINDOW_BLOCKS=80
NEXT_PUBLIC_NEXORA_LOG_CHUNK_DELAY_MS=300
PRIVATE_KEY=
# Optional. If empty, pnpm start:project creates/uses .nexora/keys/executor.local.json.
NEXORA_AGENT_EXECUTOR_PRIVATE_KEY=
# Canonical ERC-4337 EntryPoint v0.7 on Mantle Sepolia.
NEXORA_ENTRYPOINT_ADDRESS=0x0000000071727de22e5e9d8baf0edac6f37da032
NEXORA_BUNDLER_STATE_DELAY_MS=8000
NEXORA_BUNDLER_GAS_PRICE_TIER=fast

# ---------------------------------------------------------------------------
# Model providers — configure one, leave others blank
# API key values are NEVER stored in runner-config.json or sent to the browser.
# The runner reads them from this file at runtime via NEXORA_MODEL_API_KEY_ENV_VAR.
# ---------------------------------------------------------------------------

# Active provider: ollama | openai | anthropic | openai-compatible | custom
NEXORA_MODEL_PROVIDER=ollama
NEXORA_MODEL_NAME=qwen2.5:7b
NEXORA_MODEL_ENDPOINT_URL=http://127.0.0.1:11434/api/generate
NEXORA_MODEL_TEMPERATURE=0.2
NEXORA_MODEL_MAX_TOKENS=4096

# Name of the env var below that holds the active provider's API key.
# Example for OpenAI:   NEXORA_MODEL_API_KEY_ENV_VAR=OPENAI_API_KEY
# Example for Anthropic: NEXORA_MODEL_API_KEY_ENV_VAR=ANTHROPIC_API_KEY
NEXORA_MODEL_API_KEY_ENV_VAR=

# OpenAI
OPENAI_API_KEY=

# Anthropic / Claude
ANTHROPIC_API_KEY=

# Custom OpenAI-compatible endpoint
CUSTOM_MODEL_API_KEY=
